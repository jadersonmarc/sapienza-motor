# Postgres compartilhado (mesmo do core; schema public é do core, tenant_<id> é do Motor)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sapienza

# Segredo do JWT curto emitido pelo core (deve bater com PRODUCT_JWT_SECRET do core)
PRODUCT_JWT_SECRET=troque-por-um-segredo-forte

# AES-256-GCM p/ credenciais de canal por-tenant (32 bytes base64): openssl rand -base64 32
MOTOR_ENC_KEY=

# Claude (geração/análise de conteúdo)
ANTHROPIC_API_KEY=

# Canais de publicação (fornecidos no setup do cliente; mockados em teste)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# Cloudflare R2 / S3 (imagem pública p/ Instagram)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Secret dos crons (publish-scheduled / close-approval-window)
WEBHOOK_SECRET=
