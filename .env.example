# Postgres compartilhado (mesmo do core; schema public é do core, tenant_<id> é do Motor)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sapienza

# Segredo do JWT curto emitido pelo core (deve bater com PRODUCT_JWT_SECRET do core)
PRODUCT_JWT_SECRET=troque-por-um-segredo-forte

# AES-256-GCM p/ credenciais de canal por-tenant (32 bytes base64): openssl rand -base64 32
MOTOR_ENC_KEY=

# Claude (geração/análise de conteúdo). Sem ela: rascunhos/legendas caem no
# fallback determinístico e os analyzers respondem 503.
ANTHROPIC_API_KEY=

# As credenciais de canal (Instagram, LinkedIn, Facebook, X, Threads) NÃO são
# env: são fornecidas por tenant no setup e ficam cifradas em `motor_channels`
# (AES-256-GCM com MOTOR_ENC_KEY). Ver GET /api/v1/setup p/ o que cada uma exige.

# Cloudflare R2 / S3 (imagem on-brand pública). Sem o conjunto COMPLETO abaixo a
# publicação segue sem imagem — e Instagram/Threads, que exigem imagem, falham.
# S3_PUBLIC_URL = CDN pública do bucket (também é a allowlist do /api/og).
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Secret dos crons (publish-scheduled / close-approval-window / provision)
WEBHOOK_SECRET=

# Testes de integração (Postgres efêmero): psql/docker em porta separada
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:55432/sapienza_test?sslmode=disable
